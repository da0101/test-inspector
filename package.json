{
  "name": "test-inspector",
  "displayName": "Test Inspector",
  "description": "Local-first test detective for React, Vue, Flutter, Django, FastAPI, Firebase Functions, and Node.js — names which tests are theater, which are weak, and what's missing. The tool only informs; you fix.",
  "version": "0.0.3",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/da0101/test-inspector.git"
  },
  "bugs": {
    "url": "https://github.com/da0101/test-inspector/issues"
  },
  "homepage": "https://github.com/da0101/test-inspector#readme",
  "activationEvents": [
    "onView:testInspector.cases",
    "onCommand:testInspector.openCaseFile",
    "onCommand:testInspector.refresh",
    "onCommand:testInspector.configureLlm",
    "onCommand:testInspector.runCurrentFile",
    "onCommand:testInspector.exportCaseFile"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "testInspector",
          "title": "Test Inspector",
          "icon": "media/test-inspector.svg"
        }
      ]
    },
    "views": {
      "testInspector": [
        {
          "id": "testInspector.cases",
          "name": "Cases"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "testInspector.cases",
        "contents": "Test Inspector finds tests that are **theater**, **weak**, or **missing** — without running them.\n\nScanning starts automatically when you open this view. If nothing appears below, the workspace doesn't contain a recognized test project (Flutter, React, Vue, Django, FastAPI, Firebase Functions, Node).\n\n[Scan this workspace now](command:testInspector.refresh)\n[Open Case File panel](command:testInspector.openCaseFile)"
      }
    ],
    "commands": [
      {
        "command": "testInspector.openCaseFile",
        "title": "Test Inspector: Open Case File",
        "icon": "$(inspect)"
      },
      {
        "command": "testInspector.refresh",
        "title": "Test Inspector: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "testInspector.configureLlm",
        "title": "Test Inspector: Configure LLM (optional reviewer)",
        "icon": "$(key)"
      },
      {
        "command": "testInspector.runCurrentFile",
        "title": "Test Inspector: Run Tests in Current File",
        "icon": "$(run)"
      },
      {
        "command": "testInspector.exportCaseFile",
        "title": "Test Inspector: Export Case File",
        "icon": "$(file-text)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "testInspector.openCaseFile",
          "when": "view == testInspector.cases",
          "group": "navigation@0"
        },
        {
          "command": "testInspector.refresh",
          "when": "view == testInspector.cases",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "Test Inspector",
      "properties": {
        "testInspector.slowTestThresholdMs": {
          "type": "number",
          "default": 1000,
          "description": "Duration threshold used to flag slow tests."
        },
        "testInspector.maxWorkspaceFiles": {
          "type": "number",
          "default": 8000,
          "description": "Maximum files scanned per workspace folder."
        },
        "testInspector.llm.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI-compatible chat completions base URL for the optional Reviewer co-worker. Must be https (or http for localhost)."
        },
        "testInspector.llm.model": {
          "type": "string",
          "default": "gpt-4.1-mini",
          "description": "Model used by the optional Reviewer co-worker for cross-card pattern analysis and Ask-the-reviewer chat."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/unit/*.test.js",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5"
  }
}
